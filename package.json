{
  "name": "TrackLift-Pro",
  "version": "1.0.4",
  "productName": "TrackLift Pro",
  "description": "Railway Line Vertical Alignment Smoother and Chord Inspector",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "docx": "^9.7.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.shanilgd.trackliftpro",
    "productName": "TrackLift Pro",
    "artifactName": "TrackLift-Pro-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ShanilGD",
        "repo": "TrackLift-Pro"
      }
    ]
  }
}
